                        16,
                        20
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "1QYui",
                          "name": "cl1",
                          "fill": "$coral",
                          "content": "import { useState, useCallback } from 'react';",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "7qyI4",
                          "name": "cl2",
                          "fill": "$text-primary",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "DaZn9",
                          "name": "cl3",
                          "fill": "$text-primary",
                          "content": "function useCounter(initialValue = 0) {",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "3yjqE",
                          "name": "cl4",
                          "fill": "$green-accent",
                          "content": "  const [count, setCount] = useState(initialValue);",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "G1Bec",
                          "name": "cl5",
                          "fill": "$text-primary",
                          "content": "  const increment = useCallback(() => setCount(c => c + 1), []);",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "9NLhi",
                          "name": "cl6",
                          "fill": "$text-primary",
                          "content": "  const decrement = useCallback(() => setCount(c => c - 1), []);",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "qWNZO",
                          "name": "cl7",
                          "fill": "$coral",
                          "content": "  return { count, increment, decrement };",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Bq4rf",
                          "name": "cl8",
                          "fill": "$text-primary",
                          "content": "}",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "3axz6",
                  "name": "h2_2",
                  "fill": "$text-primary",
                  "content": "二、核心原理解析",
                  "fontFamily": "Oswald",
                  "fontSize": 24,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "tgSGH",
                  "name": "p2",
                  "fill": "$text-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Hooks 的核心机制基于 Fiber 架构中的链表结构。每个组件实例维护一个 hooks 链表，React 在每次渲染时按顺序遍历该链表。这就是为什么 Hooks 不能放在条件语句中——它们必须保持调用顺序的一致性。",
                  "lineHeight": 1.8,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "EyDon",
                  "name": "h2_3",
                  "fill": "$text-primary",
                  "content": "三、实战最佳实践",
                  "fontFamily": "Oswald",
                  "fontSize": 24,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "t6iqv",
                  "name": "p3",
                  "fill": "$text-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "在实际项目中，自定义 Hook 是复用逻辑的最佳方式。将组件的业务逻辑抽离到独立的 Hook 中，不仅提升了代码的可测试性，还让组件本身更加简洁。下面我们通过几个常见场景来展示最佳实践。",
                  "lineHeight": 1.8,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
