                },
                {
                  "type": "text",
                  "id": "C18Ik",
                  "name": "p1",
                  "fill": "$text-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "React Hooks 是 React 16.8 引入的新特性，允许你在函数组件中使用 state 和其他 React 特性。在此之前，只有类组件才能拥有自己的状态和生命周期方法。Hooks 的出现彻底改变了 React 的开发范式。",
                  "lineHeight": 1.8,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
